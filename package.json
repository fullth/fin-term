{
  "name": "fin-term",
  "version": "0.7.0",
  "description": "Bloomberg-style terminal: live quotes + news stream (TUI). Free data, no keys required.",
  "type": "module",
  "bin": {
    "fin-term": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "tui",
    "terminal",
    "finance",
    "stocks",
    "quotes",
    "news",
    "bloomberg",
    "cli",
    "ink"
  ],
  "license": "MIT",
  "author": "fullth <xoghksdla@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fullth/fin-term.git"
  },
  "homepage": "https://github.com/fullth/fin-term#readme",
  "bugs": {
    "url": "https://github.com/fullth/fin-term/issues"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
