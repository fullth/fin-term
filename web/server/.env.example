# fin-term web/server 환경변수 예시 — 실제 값으로 채워 .env 로 복사하거나 Railway Variables 에 등록.
# 이 파일은 키 목록·설명용이며 비밀값을 담지 않는다(커밋 OK).

# ── 방문자 추적 / 관리자 대시보드 ────────────────────────────────
# 관리자 대시보드(/admin, /api/admin/stats) Basic Auth.
# 두 값을 모두 설정해야 대시보드가 열린다. 하나라도 비면 503 으로 막혀 무인증 노출을 차단한다.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# 방문자 IP 해시 솔트. 원시 IP 는 저장하지 않고 SHA-256(SALT+IP) 해시만 보관한다.
# 미설정 시 기본 솔트가 쓰여 해시가 사실상 무력화되므로, 운영에선 반드시 길고 랜덤한 값 지정.
#   생성 예: openssl rand -hex 32
IP_HASH_SALT=

# SQLite 파일 경로. 미설정 시 web/server/data/fin-term.db (컨테이너 내부 → 재배포 시 소실).
# 운영에선 Railway Volume 마운트 경로 아래로 지정해 영속화. 디렉토리는 런타임에 자동 생성된다.
#   예: Volume mount path 가 /data 이면 → DB_PATH=/data/fin-term.db
DB_PATH=

# ── 서버 일반 ────────────────────────────────────────────────────
# 리슨 포트. Railway 는 PORT 를 주입하므로 운영에선 보통 비워둔다. 로컬 기본 8787.
PORT=

# ── 외부 시세/AI (선택) ──────────────────────────────────────────
# Finnhub API 키. 있으면 시세 우선순위 Finnhub→Yahoo→네이버. 없으면 Yahoo·네이버만 사용.
FINNHUB_KEY=

# Anthropic API 키. 설정 시 서버측 AI 브리핑/설명 제공(클라가 키 없을 때 폴백).
ANTHROPIC_API_KEY=

# ── 폴링 주기 / 기타 (선택, 기본값 있음) ─────────────────────────
# 시세 갱신 주기(ms). 기본 60000.
FIN_QUOTE_INTERVAL_MS=
# 마켓 지표 갱신 주기(ms). 기본 300000.
FIN_MARKETS_INTERVAL_MS=
